# Example configuration. Copy to .env (committed defaults) and/or
# .env.local (local overrides, gitignored).

# Web app port — the single source of truth for dev, start, PM2, and Docker.
PORT=3000

# Base URL of the OsuStocks API. Requests go to <base>/api/v1.
NEXT_PUBLIC_API_BASE_URL=http://localhost:5152

# Public site origin — base for absolute OpenGraph/Twitter image URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Analytics (optional, PostHog). Leave the key blank to disable analytics
# entirely — the app then sends nothing and never loads the PostHog bundle.
# Host defaults to https://us.i.posthog.com (use https://eu.i.posthog.com for
# EU projects). Both are inlined into the client bundle at build time.
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Legal pages (optional). A contact email shows up on Terms/Privacy when set;
# a governing-law jurisdiction adds a governing-law clause to the Terms.
# NEXT_PUBLIC_CONTACT_EMAIL=
# NEXT_PUBLIC_GOVERNING_LAW=
